{
  "name": "ru-calendar-mcp",
  "version": "1.0.0",
  "description": "MCP server: Russian relative dates and production calendar (isDayOff)",
  "type": "module",
  "license": "MIT",
  "bin": {
    "ru-calendar-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "verify": "tsx scripts/verify.ts",
    "fetch-calendars": "tsx scripts/fetch-calendars.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mcp",
    "calendar",
    "russia",
    "isdayoff",
    "production-calendar",
    "natural-language-dates"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/poker26/ru-calendar-mcp.git"
  }
}
